# ============================================================
# Content Recycler — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual API keys.
#   cp .env.example .env
# NEVER commit .env to version control.
# ============================================================

# --- LLM Provider -------------------------------------------
# Choose "openai" or "gemini"
LLM_PROVIDER=openai

# --- OpenAI -------------------------------------------------
# Required if LLM_PROVIDER=openai
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# --- Google Gemini ------------------------------------------
# Required if LLM_PROVIDER=gemini
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# --- Paths --------------------------------------------------
# Directory where ChromaDB persists its vector index
CHROMA_PERSIST_DIR=./vector_db

# Path to the historical posts CSV dataset
DATA_PATH=./data/old_posts.csv

# Path to evaluation log (JSONL format)
EVAL_LOG_FILE=./eval_scores.jsonl
